// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  garages      Garage[]
}

enum BodyType {
  Sedan
  Wagon
  Coupe
  Cabriolet
  Hatchback
  SUV
  Van
  Pickup
  Motorcycle
  Other
}

enum UnitSystem {
  Metric
  Imperial
}

enum MaintenanceCategory {
  Service
  Inspection
  Repair
  Modification
  Tires
  Fluids
  Other
}

model Garage {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String     @unique
  name        String
  description String?
  unitSystem  UnitSystem @default(Imperial)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  vehicles    Vehicle[]

  @@index([userId])
}

model Vehicle {
  id                 String              @id @default(cuid())
  garageId           String
  garage             Garage              @relation(fields: [garageId], references: [id], onDelete: Cascade)
  publicSlug         String              @unique @default(cuid())
  isPublic           Boolean             @default(false)
  featuredPhotoId    String?
  nickname           String?
  year               Int
  make               String
  model              String
  trim               String?
  registrationNumber String?
  bodyType           BodyType?
  engine             String?
  transmission       String?
  fuelType           String?
  horsepower         Int?
  torque             Int?
  color              String?
  mileage            Int                 @default(0)
  purchasedAt        DateTime?
  purchasePrice      Float?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  modifications      Modification[]
  maintenanceRecords MaintenanceRecord[]
  photos             Photo[]

  @@index([garageId])
  @@index([year, make, model])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  title       String
  category    MaintenanceCategory @default(Service)
  performedAt DateTime
  mileage     Int
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  photos      Photo[]

  @@index([vehicleId, performedAt(sort: Desc)])
}

model Modification {
  id           String   @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name         String
  category     String
  manufacturer String?
  productName  String?
  productUrl   String?
  installedAt  DateTime
  mileage      Int      @default(0)
  cost         Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photos       Photo[]

  @@index([vehicleId, installedAt(sort: Desc)])
}

model Photo {
  id                  String             @id @default(cuid())
  vehicleId           String
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  modificationId      String?
  modification        Modification?       @relation(fields: [modificationId], references: [id], onDelete: SetNull)
  maintenanceRecordId String?
  maintenanceRecord   MaintenanceRecord?  @relation(fields: [maintenanceRecordId], references: [id], onDelete: SetNull)
  url                 String
  storagePath         String
  fileName            String
  contentType         String
  size                Int
  isGallery           Boolean            @default(false)
  caption             String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([vehicleId, createdAt(sort: Desc)])
  @@index([modificationId])
  @@index([maintenanceRecordId])
}
